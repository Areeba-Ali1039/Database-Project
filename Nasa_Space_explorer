<script>
// ── DATA ──────────────────────────────────────────────────────────────────────
const exoplanets = [
  {id:'e1',name:'TRAPPIST-1 e',star:'TRAPPIST-1',method:'Transit',year:2017,radius:0.92,mass:0.62,temp:251,orbper:6.1},
  {id:'e2',name:'Kepler-452b',star:'Kepler-452',method:'Transit',year:2015,radius:1.63,mass:5.0,temp:265,orbper:384.8},
  {id:'e3',name:'HD 209458 b',star:'HD 209458',method:'Transit',year:1999,radius:1.38,mass:0.69,temp:1449,orbper:3.5},
