  {id:'e6',name:'GJ 1214 b',star:'GJ 1214',method:'Transit',year:2009,radius:2.68,mass:6.55,temp:393,orbper:1.6},
  {id:'e7',name:'55 Cancri e',star:'55 Cancri',method:'Radial Velocity',year:2004,radius:1.99,mass:8.08,temp:2709,orbper:0.74},
  {id:'e8',name:'Proxima b',star:'Proxima Centauri',method:'Radial Velocity',year:2016,radius:1.1,mass:1.27,temp:234,orbper:11.2},
  {id:'e9',name:'WASP-12 b',star:'WASP-12',method:'Transit',year:2008,radius:1.9,mass:1.47,temp:2585,orbper:1.09},
  {id:'e10',name:'Kepler-22b',star:'Kepler-22',method:'Transit',year:2011,radius:2.38,mass:null,temp:295,orbper:289.9},
  {id:'e11',name:'LHS 1140 b',star:'LHS 1140',method:'Transit',year:2017,radius:1.73,mass:6.98,temp:230,orbper:24.7},
  {id:'e12',name:'TOI-700 d',star:'TOI-700',method:'Transit',year:2020,radius:1.14,mass:null,temp:269,orbper:37.4},
];

const blackholes = [
  {id:'b1',name:'Cygnus X-1',type:'Stellar',mass_solar:21.2,galaxy:'Milky Way',dist_ly:6070,discovered:1964},
  {id:'b2',name:'Sagittarius A*',type:'Supermassive',mass_solar:4.1e6,galaxy:'Milky Way',dist_ly:26000,discovered:1974},
  {id:'b3',name:'M87*',type:'Supermassive',mass_solar:6.5e9,galaxy:'Messier 87',dist_ly:5.4e7,discovered:1918},
  {id:'b4',name:'GRS 1915+105',type:'Stellar',mass_solar:14.0,galaxy:'Milky Way',dist_ly:36000,discovered:1992},
  {id:'b5',name:'V404 Cygni',type:'Stellar',mass_solar:9.0,galaxy:'Milky Way',dist_ly:7800,discovered:1989},
  {id:'b6',name:'NGC 1277 BH',type:'Supermassive',mass_solar:1.7e10,galaxy:'NGC 1277',dist_ly:2.2e8,discovered:2012},
  {id:'b7',name:'TON 618',type:'Supermassive',mass_solar:6.6e10,galaxy:'TON 618',dist_ly:1.05e10,discovered:1970},
  {id:'b8',name:'A0620-00',type:'Stellar',mass_solar:6.6,galaxy:'Milky Way',dist_ly:3300,discovered:1975},
];

const galaxies = [
  {id:'g1',name:'Milky Way',type:'Spiral',dist_mly:0,stars:'200-400B',diameter_ly:105700,bhs:2,exoplanets:5600},
  {id:'g2',name:'Andromeda (M31)',type:'Spiral',dist_mly:2.537,stars:'1T',diameter_ly:220000,bhs:1,exoplanets:0},
  {id:'g3',name:'Messier 87',type:'Elliptical',dist_mly:53.5,stars:'1T',diameter_ly:980000,bhs:1,exoplanets:0},
  {id:'g4',name:'Large Magellanic Cloud',type:'Irregular',dist_mly:0.158,stars:'30B',diameter_ly:14000,bhs:0,exoplanets:0},
  {id:'g5',name:'Triangulum (M33)',type:'Spiral',dist_mly:2.73,stars:'40B',diameter_ly:60000,bhs:0,exoplanets:0},
  {id:'g6',name:'NGC 1277',type:'Elliptical',dist_mly:220,stars:'~300B',diameter_ly:40000,bhs:1,exoplanets:0},
  {id:'g7',name:'Small Magellanic Cloud',type:'Irregular',dist_mly:0.197,stars:'3B',diameter_ly:7000,bhs:0,exoplanets:0},
  {id:'g8',name:'Centaurus A',type:'Elliptical',dist_mly:13.7,stars:'~100B',diameter_ly:60000,bhs:1,exoplanets:0},
];

// ── STATE ─────────────────────────────────────────────────────────────────────
let favourites = {};
let notes = {};
let openNote = null;

// ── STARS BACKGROUND ──────────────────────────────────────────────────────────
(function(){
  const c=document.getElementById('stars');
  for(let i=0;i<180;i++){
    const s=document.createElement('div');
    s.className='star';
    const size=Math.random()*2+0.5;
    s.style.cssText=`width:${size}px;height:${size}px;left:${Math.random()*100}%;top:${Math.random()*100}%;--d:${2+Math.random()*4}s;--delay:${Math.random()*4}s;--min:${0.05+Math.random()*0.15};--max:${0.4+Math.random()*0.6}`;
    c.appendChild(s);
  }
})();

// ── HELPERS ───────────────────────────────────────────────────────────────────
function fmt(n){
  if(n===null||n===undefined) return '—';
  if(n>=1e9) return (n/1e9).toFixed(1)+'B☉';
  if(n>=1e6) return (n/1e6).toFixed(2)+'M☉';
  return n.toLocaleString();
}
function fmtDist(n){
  if(n===0) return 'We are here';
  if(n>=1e6) return (n/1e6).toFixed(2)+'B ly';
  if(n>=1000) return (n/1000).toFixed(2)+'K ly';
  return n+' ly';
}
function methodBadge(m){
  if(m==='Transit') return 'transit';
  if(m==='Radial Velocity') return 'rv';
  return 'imaging';
}
function toggleFav(id,label){
  if(favourites[id]){delete favourites[id]}else{favourites[id]={id,label}}
  refreshFavs();
  // re-render all grids to update star buttons
  renderAll();
}
function toggleNote(id){
  if(openNote===id){openNote=null}else{openNote=id}
  renderAll();
}
function saveNote(id){
  const ta=document.getElementById('note-'+id);
  if(ta){notes[id]=ta.value}
}

// ── RENDER EXOPLANETS ──────────────────────────────────────────────────────────
function renderExo(list,targetId){
  const g=document.getElementById(targetId);
  if(!g) return;
  g.innerHTML='';
  list.forEach((p,i)=>{
    const isFav=!!favourites[p.id];
    const noteOpen=openNote===p.id;
    const div=document.createElement('div');
    div.innerHTML=`
      <div class="card" style="animation-delay:${i*0.04}s">
        <button class="fav-btn ${isFav?'active':''}" onclick="toggleFav('${p.id}','${p.name}');event.stopPropagation()">${isFav?'★':'☆'}</button>
        <div class="card-type" style="color:var(--accent)"><div class="card-type-dot" style="background:var(--accent)"></div>EXOPLANET</div>
        <div class="card-name">${p.name}</div>
        <div class="card-rows">
          <div class="card-row"><span class="card-key">Host Star</span><span class="card-val">${p.star}</span></div>
          <div class="card-row"><span class="card-key">Discovered</span><span class="card-val">${p.year}</span></div>
          <div class="card-row"><span class="card-key">Orbit Period</span><span class="card-val">${p.orbper} days</span></div>
          <div class="card-row"><span class="card-key">Radius</span><span class="card-val">${p.radius} R♃</span></div>
          <div class="card-row"><span class="card-key">Eq. Temp</span><span class="card-val">${p.temp} K</span></div>
        </div>
        <span class="card-badge badge-${methodBadge(p.method)}">${p.method}</span>
        <div style="margin-top:12px;font-size:10px;color:var(--muted);cursor:pointer;letter-spacing:1px" onclick="toggleNote('${p.id}')">${noteOpen?'▾':'▸'} NOTES ${notes[p.id]?'●':''}</div>
        <div class="notes-panel ${noteOpen?'open':''}">
          <h4>USER NOTES — ${p.name}</h4>
          <textarea id="note-${p.id}" placeholder="Add your annotation...">${notes[p.id]||''}</textarea>
          <button onclick="saveNote('${p.id}');toggleNote('${p.id}')">SAVE NOTE</button>
        </div>
      </div>`;
