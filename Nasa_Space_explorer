// ── FAVOURITES ─────────────────────────────────────────────────────────────────
function refreshFavs(){
  const keys=Object.keys(favourites);
  const fe=document.getElementById('fav-empty');
  const fg=document.getElementById('fav-grid');
  if(!fg) return;
  if(keys.length===0){
    fg.innerHTML='';
    if(fe) fe.style.display='block';
    return;
  }
  if(fe) fe.style.display='none';
  const favExo=exoplanets.filter(p=>favourites[p.id]);
  const favBH=blackholes.filter(b=>favourites[b.id]);
  const favGal=galaxies.filter(g=>favourites[g.id]);
  fg.innerHTML='';
  renderExo(favExo,'fav-grid');
  // append BH + galaxies into same grid
  const tempBH=document.createElement('div');tempBH.id='temp-bh';fg.appendChild(tempBH);
  renderBH(favBH,'temp-bh');
  while(tempBH.firstChild){fg.appendChild(tempBH.firstChild);}
  fg.removeChild(tempBH);
  const tempGal=document.createElement('div');tempGal.id='temp-gal';fg.appendChild(tempGal);
  renderGal(favGal,'temp-gal');
  while(tempGal.firstChild){fg.appendChild(tempGal.firstChild);}
  fg.removeChild(tempGal);
}

function renderAll(){
  renderExo(exoplanets,'exo-grid');
  renderBH(blackholes,'bh-grid');
  renderGal(galaxies,'gal-grid');
  refreshFavs();
}

// ── SECTIONS ───────────────────────────────────────────────────────────────────
function showSection(id){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  const map={home:0,exoplanets:1,blackholes:2,galaxies:3,favourites:4};
  document.querySelectorAll('.nav-btn')[map[id]].classList.add('active');
  if(id==='favourites') refreshFavs();
}

// ── FILTER ─────────────────────────────────────────────────────────────────────
function filterCards(type,val,btn){
  btn.parentNode.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  if(type==='exo'){
    const list=val==='all'?exoplanets:exoplanets.filter(p=>p.method===val);
    renderExo(list,'exo-grid');
  }else if(type==='bh'){
    const list=val==='all'?blackholes:blackholes.filter(b=>b.type===val);
    renderBH(list,'bh-grid');
  }else{
    const list=val==='all'?galaxies:galaxies.filter(g=>g.type===val);
    renderGal(list,'gal-grid');
  }
}

// ── SEARCH ─────────────────────────────────────────────────────────────────────
function globalSearch(q){
  const sr=document.getElementById('search-results');
  const sg=document.getElementById('search-grid');
  const sl=document.getElementById('search-label');
  if(!q||q.length<2){sr.style.display='none';return;}
  q=q.toLowerCase();
  const ex=exoplanets.filter(p=>p.name.toLowerCase().includes(q)||p.star.toLowerCase().includes(q)||p.method.toLowerCase().includes(q));
  const bh=blackholes.filter(b=>b.name.toLowerCase().includes(q)||b.type.toLowerCase().includes(q)||b.galaxy.toLowerCase().includes(q));
  const gal=galaxies.filter(g=>g.name.toLowerCase().includes(q)||g.type.toLowerCase().includes(q));
  const total=ex.length+bh.length+gal.length;
  sr.style.display='block';
  sl.textContent=`// ${total} result${total!==1?'s':''} for "${q}"`;
  sg.innerHTML='';
  const t1=document.createElement('div');t1.id='sr-exo';sg.appendChild(t1);
  renderExo(ex,'sr-exo');while(t1.firstChild){sg.appendChild(t1.firstChild);}sg.removeChild(t1);
  const t2=document.createElement('div');t2.id='sr-bh';sg.appendChild(t2);
  renderBH(bh,'sr-bh');while(t2.firstChild){sg.appendChild(t2.firstChild);}sg.removeChild(t2);
  const t3=document.createElement('div');t3.id='sr-gal';sg.appendChild(t3);
  renderGal(gal,'sr-gal');while(t3.firstChild){sg.appendChild(t3.firstChild);}sg.removeChild(t3);
}

// ── INIT ───────────────────────────────────────────────────────────────────────
renderAll();
</script>
