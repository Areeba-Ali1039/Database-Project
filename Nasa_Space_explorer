// ── RENDER BLACK HOLES ─────────────────────────────────────────────────────────
function renderBH(list,targetId){
  const g=document.getElementById(targetId);
  if(!g) return;
  g.innerHTML='';
  list.forEach((b,i)=>{
    const isFav=!!favourites[b.id];
    const noteOpen=openNote===b.id;
    const div=document.createElement('div');
    div.innerHTML=`
      <div class="card" style="animation-delay:${i*0.04}s">
        <button class="fav-btn ${isFav?'active':''}" onclick="toggleFav('${b.id}','${b.name}');event.stopPropagation()">${isFav?'★':'☆'}</button>
        <div class="card-type" style="color:var(--red)"><div class="card-type-dot" style="background:var(--red)"></div>BLACK HOLE</div>
        <div class="card-name">${b.name}</div>
        <div class="card-rows">
          <div class="card-row"><span class="card-key">Type</span><span class="card-val">${b.type}</span></div>
          <div class="card-row"><span class="card-key">Mass</span><span class="card-val">${fmt(b.mass_solar)} M☉</span></div>
          <div class="card-row"><span class="card-key">Galaxy</span><span class="card-val">${b.galaxy}</span></div>
          <div class="card-row"><span class="card-key">Distance</span><span class="card-val">${fmtDist(b.dist_ly)}</span></div>
