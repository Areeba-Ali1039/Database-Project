
<!DOCTYPE html>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap');

  *{margin:0;padding:0;box-sizing:border-box}
  :root{
    --space:#020408;
    --deep:#060d1a;
    --card:#0a1628;
    --card2:#0d1f3c;
    --accent:#00d4ff;
    --accent2:#7b2fff;
    --gold:#ffc849;
    --red:#ff4d6d;
    --text:#c8dff0;
    --muted:#4a6a8a;
    --border:rgba(0,212,255,0.12);
  }
  body{
    background:var(--space);
    color:var(--text);
    font-family:'Space Mono',monospace;
    min-height:100vh;
    overflow-x:hidden;
  }

  /* starfield */
  #stars{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
  .star{position:absolute;border-radius:50%;background:#fff;animation:twinkle var(--d,3s) ease-in-out infinite var(--delay,0s)}
  @keyframes twinkle{0%,100%{opacity:var(--min,0.1)}50%{opacity:var(--max,0.8)}}

  /* nav */
  nav{position:relative;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:18px 40px;border-bottom:1px solid var(--border);background:rgba(2,4,8,0.85);backdrop-filter:blur(12px)}
  .logo{font-family:'Orbitron',monospace;font-weight:900;font-size:16px;color:#fff;letter-spacing:3px;display:flex;align-items:center;gap:10px}
  .logo-dot{width:8px;height:8px;background:var(--accent);border-radius:50%;box-shadow:0 0 8px var(--accent);animation:pulse 2s ease-in-out infinite}
  @keyframes pulse{0%,100%{box-shadow:0 0 8px var(--accent)}50%{box-shadow:0 0 20px var(--accent),0 0 40px var(--accent)}}
  .nav-links{display:flex;gap:8px}
  .nav-btn{background:none;border:1px solid var(--border);color:var(--muted);font-family:'Space Mono',monospace;font-size:11px;padding:7px 16px;cursor:pointer;border-radius:4px;letter-spacing:1px;transition:all .2s;text-transform:uppercase}
  .nav-btn:hover,.nav-btn.active{color:var(--accent);border-color:var(--accent);background:rgba(0,212,255,0.06)}

  /* hero */
  .hero{position:relative;z-index:10;text-align:center;padding:80px 40px 60px}
  .hero-tag{font-size:10px;letter-spacing:4px;color:var(--accent);text-transform:uppercase;margin-bottom:20px;opacity:.7}
  .hero-title{font-family:'Orbitron',monospace;font-size:clamp(28px,5vw,56px);font-weight:900;color:#fff;line-height:1.1;margin-bottom:16px;text-shadow:0 0 40px rgba(0,212,255,0.3)}
  .hero-title span{color:var(--accent)}
  .hero-sub{font-size:12px;color:var(--muted);max-width:480px;margin:0 auto 36px;line-height:1.8;letter-spacing:.5px}
  .hero-stats{display:flex;justify-content:center;gap:40px;margin-bottom:40px}
  .stat{text-align:center}
  .stat-num{font-family:'Orbitron',monospace;font-size:24px;font-weight:700;color:#fff}
  .stat-label{font-size:9px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-top:4px}
  .search-bar{display:flex;max-width:500px;margin:0 auto;border:1px solid var(--border);border-radius:6px;overflow:hidden;background:var(--card);transition:border-color .2s}
  .search-bar:focus-within{border-color:var(--accent)}
  .search-bar input{flex:1;background:none;border:none;padding:13px 18px;color:#fff;font-family:'Space Mono',monospace;font-size:12px;outline:none}
  .search-bar input::placeholder{color:var(--muted)}
  .search-bar button{background:var(--accent);border:none;padding:13px 20px;cursor:pointer;font-family:'Orbitron',monospace;font-size:10px;font-weight:700;color:#000;letter-spacing:2px;transition:background .2s}
  .search-bar button:hover{background:#fff}

  /* sections */
  .section{position:relative;z-index:10;padding:0 40px 60px;display:none}
  .section.active{display:block}
  .section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;padding-bottom:16px;border-bottom:1px solid var(--border)}
  .section-title{font-family:'Orbitron',monospace;font-size:18px;font-weight:700;color:#fff;letter-spacing:2px}
  .section-title span{color:var(--accent)}
  .filter-row{display:flex;gap:8px;flex-wrap:wrap}
  .filter-btn{background:none;border:1px solid var(--border);color:var(--muted);font-family:'Space Mono',monospace;font-size:10px;padding:6px 14px;cursor:pointer;border-radius:3px;letter-spacing:1px;transition:all .2s}
  .filter-btn:hover,.filter-btn.active{color:var(--accent);border-color:rgba(0,212,255,0.4);background:rgba(0,212,255,0.05)}

  /* grid */
  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}

  /* cards */
  .card{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:22px;cursor:pointer;transition:all .25s;position:relative;overflow:hidden}
  .card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,212,255,0.03),transparent);opacity:0;transition:opacity .3s}
  .card:hover{border-color:rgba(0,212,255,0.3);transform:translateY(-2px);box-shadow:0 8px 32px rgba(0,212,255,0.08)}
  .card:hover::before{opacity:1}
  .card-type{font-size:9px;letter-spacing:2px;text-transform:uppercase;margin-bottom:10px;display:flex;align-items:center;gap:6px}
  .card-type-dot{width:6px;height:6px;border-radius:50%}
  .card-name{font-family:'Orbitron',monospace;font-size:13px;font-weight:700;color:#fff;margin-bottom:12px;line-height:1.4}
  .card-rows{display:flex;flex-direction:column;gap:6px}
  .card-row{display:flex;justify-content:space-between;align-items:center;font-size:10px}
  .card-key{color:var(--muted);letter-spacing:.5px}
  .card-val{color:var(--text);font-weight:700}
  .card-badge{display:inline-block;font-size:9px;padding:3px 8px;border-radius:2px;letter-spacing:1px;text-transform:uppercase;margin-top:12px}
  .badge-transit{background:rgba(0,212,255,0.1);color:var(--accent);border:1px solid rgba(0,212,255,0.2)}
  .badge-rv{background:rgba(123,47,255,0.1);color:#a78bfa;border:1px solid rgba(123,47,255,0.2)}
  .badge-imaging{background:rgba(255,200,73,0.1);color:var(--gold);border:1px solid rgba(255,200,73,0.2)}
  .badge-stellar{background:rgba(255,77,109,0.1);color:var(--red);border:1px solid rgba(255,77,109,0.2)}
  .badge-supermassive{background:rgba(255,77,109,0.12);color:var(--red);border:1px solid rgba(255,77,109,0.25)}
  .badge-spiral{background:rgba(0,212,255,0.1);color:var(--accent);border:1px solid rgba(0,212,255,0.2)}
  .badge-elliptical{background:rgba(255,200,73,0.1);color:var(--gold);border:1px solid rgba(255,200,73,0.2)}
  .badge-irregular{background:rgba(123,47,255,0.1);color:#a78bfa;border:1px solid rgba(123,47,255,0.2)}
  .fav-btn{position:absolute;top:14px;right:14px;background:none;border:none;cursor:pointer;font-size:14px;color:var(--muted);transition:all .2s}
  .fav-btn:hover,.fav-btn.active{color:var(--gold);transform:scale(1.2)}

  /* notes panel */
  .notes-panel{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:20px;margin-top:16px;display:none}
  .notes-panel.open{display:block}
  .notes-panel h4{font-family:'Orbitron',monospace;font-size:12px;color:var(--accent);margin-bottom:12px;letter-spacing:2px}
  .notes-panel textarea{width:100%;background:var(--deep);border:1px solid var(--border);border-radius:4px;padding:12px;color:var(--text);font-family:'Space Mono',monospace;font-size:11px;resize:none;height:80px;outline:none;transition:border-color .2s}
  .notes-panel textarea:focus{border-color:rgba(0,212,255,0.3)}
  .notes-panel button{margin-top:10px;background:var(--accent);border:none;padding:8px 18px;color:#000;font-family:'Orbitron',monospace;font-size:10px;font-weight:700;cursor:pointer;border-radius:3px;letter-spacing:1px}

  /* favourites section */
  .fav-empty{text-align:center;padding:60px;color:var(--muted);font-size:12px;letter-spacing:1px}
  .fav-empty span{display:block;font-size:32px;margin-bottom:12px}

  /* footer */
  footer{position:relative;z-index:10;text-align:center;padding:24px;border-top:1px solid var(--border);font-size:10px;color:var(--muted);letter-spacing:1px}

  /* animations */
  .card{animation:fadeUp .4s ease both}
  @keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
</style>

<div id="stars"></div>

<nav>
  <div class="logo"><div class="logo-dot"></div>NASA EXPLORER</div>
  <div class="nav-links">
